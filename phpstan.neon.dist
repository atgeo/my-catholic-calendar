parameters:
    level: 6
    phpVersion: 80100
    paths:
        - src
    # my-catholic-calendar.php defines the plugin constants (MY_CATHOLIC_CALENDAR_FILE, MY_CATHOLIC_CALENDAR_PATH, …)
    # referenced from src/; scanning it lets PHPStan resolve them.
    scanFiles:
        - my-catholic-calendar.php
    # WordPress core stubs are provided by szepeviktor/phpstan-wordpress,
    # auto-registered via phpstan/extension-installer.
