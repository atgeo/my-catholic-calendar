# Files and directories excluded from the distributed (WordPress.org) build.
# Everything NOT listed here ships — notably vendor/, build/, src/,
# my-catholic-calendar.php, uninstall.php, composer.json, readme.txt.

/.git
/.github
/.wordpress-org
/node_modules
/tests
/blocks
/assets
/languages
/LICENSE

/.gitignore
/.distignore
/.editorconfig
/.wp-env.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpunit.xml.dist
/composer.lock
/package.json
/package-lock.json
/README.md
/CLAUDE.md
# Exclude vendor docs and editor metadata
/vendor/**/README*
/vendor/**/CHANGELOG*
/vendor/**/CONTRIBUTING*
/vendor/**/phpstan.neon.dist
/vendor/**/phpunit.xml.dist
/vendor/**/phpcs.xml.dist
/vendor/**/composer.lock
/vendor/**/package.json
/vendor/**/captainhook.json
/vendor/**/.vscode
/vendor/**/.github
/vendor/**/.gitignore
/vendor/**/.DS_Store
/vendor/**/CLAUDE.md
/vendor/**/CODE_OF_CONDUCT.md
/vendor/**/examples
