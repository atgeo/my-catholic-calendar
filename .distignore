# Files and directories excluded from the distributed (WordPress.org) build.
# Everything NOT listed here ships — notably vendor/, build/, languages/,
# src/, kalenda.php, uninstall.php, composer.json, readme.txt and LICENSE.

/.git
/.github
/.wordpress-org
/node_modules
/tests
/blocks
/assets

/.gitignore
/.distignore
/.editorconfig
/.wp-env.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpunit.xml.dist
/composer.lock
/package.json
/package-lock.json
/README.md
/CLAUDE.md
# Exclude vendor docs and editor metadata
/vendor/**/README*
/vendor/**/CHANGELOG*
/vendor/**/CONTRIBUTING*
/.DS_Store
