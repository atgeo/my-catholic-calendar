<?xml version="1.0"?>
<ruleset name="Kalenda">
	<description>Coding standards for the Kalenda plugin.</description>

	<!-- Scan the whole plugin by default. -->
	<file>.</file>

	<!-- Directories that should never be sniffed. -->
	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>/build/*</exclude-pattern>
	<exclude-pattern>/tests/*</exclude-pattern>

	<!-- Only check PHP files. -->
	<arg name="extensions" value="php"/>

	<!-- Show sniff codes and progress, use colours, run in parallel. -->
	<arg name="colors"/>
	<arg value="sp"/>
	<arg name="parallel" value="8"/>

	<!-- Minimum supported WordPress version for deprecation checks. -->
	<config name="minimum_wp_version" value="6.5"/>

	<!-- Base WordPress standard (code style + best practices). -->
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<!--
		src/ uses PSR-4 autoloading (StudlyCase class files), which is
		incompatible with WordPress core's class-*.php file naming. PSR-4 is a
		deliberate architectural choice, so exempt src/ from the naming sniffs.
	-->
	<rule ref="WordPress.Files.FileName.NotHyphenatedLowercase">
		<exclude-pattern>/src/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.Files.FileName.InvalidClassFileName">
		<exclude-pattern>/src/*</exclude-pattern>
	</rule>

	<!-- Require our prefix on all global symbols. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="Kalenda"/>
				<element value="kalenda"/>
				<element value="KALENDA"/>
			</property>
		</properties>
		<!--
			Block render.php templates have no namespace and assign top-level
			variables by design ($attributes, $content, $block, and everything a
			template derives from them) — but WordPress core always includes them
			from inside WP_Block_Type::render()'s method scope, so these are local
			variables, not real global-namespace pollution. PrefixAllGlobals has no
			file-scoping awareness (unlike GlobalVariablesOverride's
			treat_files_as_scoped), so exempt this specific, well-understood path.
		-->
		<exclude-pattern>/blocks/*/render\.php</exclude-pattern>
	</rule>

	<!--
		Same rationale as above: render.php locals (e.g. $title) can coincide with
		names WordPress core treats as protectable globals, even though they are
		include-scoped locals here, not the real global. Rather than rely on the
		sniff's own treat_files_as_scoped switch (which would apply plugin-wide),
		scope the exemption to the same render.php path for consistency.
	-->
	<rule ref="WordPress.WP.GlobalVariablesOverride">
		<exclude-pattern>/blocks/*/render\.php</exclude-pattern>
	</rule>

	<!-- Enforce a single, correct text domain. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="kalenda"/>
			</property>
		</properties>
	</rule>

	<!--
		The gateway/domain layer throws exceptions purely as developer
		diagnostics. Every one is caught at the REST boundary and converted into
		a WP_Error response, so exception messages are never echoed as HTML.
		Escaping them would couple the WP-agnostic domain objects to esc_html(),
		so the "exception not escaped" sniff is disabled for src/ only.
	-->
	<rule ref="WordPress.Security.EscapeOutput.ExceptionNotEscaped">
		<exclude-pattern>/src/*</exclude-pattern>
	</rule>
</ruleset>
