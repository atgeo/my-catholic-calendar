#. Description of the plugin
#: kalenda.php
msgid ""
"Displays the Catholic liturgical calendar on any WordPress theme, powered by "
"the LitCal API."
msgstr ""
"Affiche le calendrier liturgique catholique sur n’importe quel thème "
"WordPress, grâce à l’API LitCal."

#. Author of the plugin
#: kalenda.php
msgid "Georges Kmeid"
msgstr "Georges Kmeid"

