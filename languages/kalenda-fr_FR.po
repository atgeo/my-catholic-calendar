msgid "This block is not configured correctly."
msgstr "Ce bloc n’est pas configuré correctement."

#: blocks/day/render.php:48 build/day/render.php:48
msgid "Unable to load today's celebrations."
msgstr "Impossible de charger les célébrations d’aujourd’hui"

