#: src/Repositories/CalendarRepository.php:89
#, php-format
msgid "Unsupported locale for this calendar: %s"
msgstr "Paramètre régional non pris en charge pour ce calendrier : %s"

#: src/Repositories/CalendarRepository.php:120
