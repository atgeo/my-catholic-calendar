msgstr "Aucune célébration pour aujourd’hui"

#: kalenda.php:65
msgid "Kalenda:"
msgstr "Kalenda:"

#. translators: 1: required PHP version, 2: current PHP version.
#: kalenda.php:82
#, php-format
msgid "requires PHP %1$s or newer. You are running PHP %2$s."
msgstr "nécessite PHP %1$s ou une version ultérieure. Vous utilisez actuellement PHP %2$s"

#. translators: 1: required WordPress version, 2: current WordPress version.
#: kalenda.php:94
#, php-format
msgid "requires WordPress %1$s or newer. Please update WordPress."
msgstr "nécessite WordPress %1$s ou une version ultérieure. Veuillez mettre à jour WordPress."

#: kalenda.php:104
msgid ""
"is missing its Composer dependencies. Run \"composer install\" in the plugin "
"directory."
msgstr ""
"ne dispose pas de ses dépendances Composer. Exécutez « composer install » "
"dans le répertoire de l’extension."

#. translators: 1: calendar type (nation or diocese), 2: requested id.
